# Copy to .env and fill in your key. Free-tier Gemini API key from https://aistudio.google.com/apikey
# Witness never enables billing; it assumes free-tier rate limits and backs off on 429.
GEMINI_API_KEY=your-key-here

# Optional. Controls how the LLM client sources responses (see config.py). Default: auto.
#   auto   -> replay from cassette if present, else call live and record (needs key)
#   replay -> replay only; error if a cassette is missing (fully offline, reproducible)
#   record -> always call live and (re)record the cassette (needs key)
#   live   -> always call live, never touch cassettes (needs key)
# LLM_MODE=auto
